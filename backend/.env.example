# Server
PORT=5000
NODE_ENV=development
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=vrbms
DB_USER=root
DB_PASSWORD=changeme

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Payment Gateways (use TEST keys until go-live)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
STRIPE_SECRET_KEY=

# Google Maps
GOOGLE_MAPS_API_KEY=

+ # WhatsApp Cloud API (sends booking confirmation to customer + vehicle contact number)
+ # See src/utils/whatsapp.js for setup steps.
+ WHATSAPP_TOKEN=
+ WHATSAPP_PHONE_NUMBER_ID=
+ WHATSAPP_API_VERSION=v20.0

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Vehicle Rentals <no-reply@yourdomain.com>"
